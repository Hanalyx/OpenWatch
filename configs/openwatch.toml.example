# OpenWatch — example configuration file
#
# In production this file lives at /etc/openwatch/openwatch.toml.
# For local development, point to it with `--config configs/openwatch.toml.example`.
#
# Layering (highest precedence first):
#   1. CLI flags        (--listen, --log-level, ...)
#   2. Env vars         (OPENWATCH_<SECTION>_<KEY>)
#   3. This TOML file
#   4. Built-in defaults

[server]
listen   = "0.0.0.0:8443"
tls_cert = "/etc/openwatch/tls/cert.pem"
tls_key  = "/etc/openwatch/tls/key.pem"

[database]
dsn             = "postgres://openwatch@localhost/openwatch?sslmode=disable"
max_connections = 25

[logging]
level  = "info"     # debug | info | warn | error
format = "json"     # json | text

[identity]
# RSA private key (PEM, PKCS#1 or PKCS#8, >= 2048 bits, mode 0600).
# Signs access + refresh tokens. Required — `serve` fails to boot
# without it.
jwt_private_key = "/etc/openwatch/keys/jwt_private.pem"

# AES-256 raw-binary key (32 bytes, mode 0600). Encrypts MFA secrets
# and stored SSH credentials. Required — `serve` fails to boot without
# it.
credential_key_file = "/etc/openwatch/keys/credential.key"
