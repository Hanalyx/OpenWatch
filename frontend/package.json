{
  "name": "openwatch-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "OpenWatch React 19 + MUI v7 SPA. Embedded into the Go binary at frontend/dist via go:embed. See docs/engineering/frontend_architecture_adr.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "api:types": "openapi-typescript ../api/openapi.yaml -o src/api/schema.d.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@hookform/resolvers": "^3.9.1",
    "@mui/material": "^7.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.85.0",
    "lucide-react": "^0.460.0",
    "openapi-fetch": "^0.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.54.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.0",
    "@tanstack/router-devtools": "^1.85.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
