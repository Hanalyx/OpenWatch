#!/bin/bash
# OpenWatch Debian Post-Installation Script
# Configure native deployment after package installation

set -e

# Service user
SERVICE_USER="openwatch"
SERVICE_GROUP="openwatch"

# Paths
CONFIG_DIR="/etc/openwatch"
OPT_DIR="/opt/openwatch"

# Colors for output
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

log_info() {
    echo -e "${BLUE}openwatch:${NC} $1"
}

log_success() {
    echo -e "${GREEN}openwatch:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}openwatch:${NC} $1"
}

case "$1" in
    configure)
        # Create service user and group
        if ! getent group $SERVICE_GROUP >/dev/null; then
            log_info "Creating $SERVICE_GROUP group..."
            addgroup --system $SERVICE_GROUP
        fi

        if ! getent passwd $SERVICE_USER >/dev/null; then
            log_info "Creating $SERVICE_USER user..."
            adduser --system --ingroup $SERVICE_GROUP --home /var/lib/openwatch \
                    --shell /usr/sbin/nologin --comment "OpenWatch service account" \
                    $SERVICE_USER
        fi

        # Create directory structure
        log_info "Creating directory structure..."
        install -d -m 750 -o $SERVICE_USER -g $SERVICE_GROUP $CONFIG_DIR
        install -d -m 700 -o $SERVICE_USER -g $SERVICE_GROUP $CONFIG_DIR/ssh
        install -d -m 700 -o $SERVICE_USER -g $SERVICE_GROUP $CONFIG_DIR/ssl
        install -d -m 755 -o $SERVICE_USER -g $SERVICE_GROUP /var/lib/openwatch
        install -d -m 755 -o $SERVICE_USER -g $SERVICE_GROUP /var/log/openwatch
        install -d -m 755 -o $SERVICE_USER -g $SERVICE_GROUP /var/cache/openwatch

        # Set ownership and permissions on installed files
        log_info "Setting ownership and permissions..."
        chown -R $SERVICE_USER:$SERVICE_GROUP $OPT_DIR
        chown -R $SERVICE_USER:$SERVICE_GROUP $CONFIG_DIR
        chown -R $SERVICE_USER:$SERVICE_GROUP /var/lib/openwatch
        chown -R $SERVICE_USER:$SERVICE_GROUP /var/log/openwatch

        chmod 750 $CONFIG_DIR
        chmod 700 $CONFIG_DIR/ssh
        chmod 700 $CONFIG_DIR/ssl
        chmod 600 $CONFIG_DIR/secrets.env 2>/dev/null || true

        # Make application dirs accessible
        chmod -R 755 $OPT_DIR
        chmod 644 $OPT_DIR/backend/requirements.txt

        # Create Python virtual environment
        log_info "Creating Python virtual environment..."
        if [ ! -d $OPT_DIR/venv/bin ]; then
            python3 -m venv $OPT_DIR/venv
            $OPT_DIR/venv/bin/pip install --upgrade pip wheel
            $OPT_DIR/venv/bin/pip install -r $OPT_DIR/backend/requirements.txt
            chown -R $SERVICE_USER:$SERVICE_GROUP $OPT_DIR/venv
        fi

        # Generate secrets if they contain defaults
        if grep -q "CHANGEME" $CONFIG_DIR/secrets.env 2>/dev/null; then
            log_info "Generating initial secrets..."
            /usr/share/openwatch/scripts/generate-secrets.sh || true
        fi

        # Generate JWT key pair if missing
        if [ ! -f $CONFIG_DIR/jwt_private.pem ]; then
            log_info "Generating JWT key pair..."
            openssl genpkey -algorithm RSA -out $CONFIG_DIR/jwt_private.pem \
                -pkeyopt rsa_keygen_bits:2048 2>/dev/null
            openssl pkey -in $CONFIG_DIR/jwt_private.pem -pubout \
                -out $CONFIG_DIR/jwt_public.pem 2>/dev/null
            chmod 600 $CONFIG_DIR/jwt_private.pem
            chmod 644 $CONFIG_DIR/jwt_public.pem
            chown $SERVICE_USER:$SERVICE_GROUP $CONFIG_DIR/jwt_private.pem $CONFIG_DIR/jwt_public.pem
            log_success "JWT keys generated"
        fi

        # Configure AppArmor (Ubuntu-specific, analogous to SELinux on RHEL)
        if command -v aa-status >/dev/null 2>&1; then
            log_info "Configuring AppArmor profiles..."
            cat > /etc/apparmor.d/openwatch << 'EOF'
# OpenWatch AppArmor Profile
#include <tunables/global>

profile openwatch flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/python>

  # Application binaries
  /opt/openwatch/venv/bin/* ix,
  /opt/openwatch/backend/** r,
  /opt/openwatch/frontend/** r,
  /opt/openwatch/backend/kensa/** r,
  /usr/bin/owadm ix,

  # Configuration (read-only)
  /etc/openwatch/** r,
  /etc/openwatch/secrets.env r,
  /etc/openwatch/ssh/** r,

  # Data directories
  /var/lib/openwatch/** rw,
  /var/log/openwatch/** rw,
  /var/cache/openwatch/** rw,

  # Venv libraries
  /opt/openwatch/venv/lib/** mr,

  # Deny sensitive operations
  deny /etc/passwd* w,
  deny /etc/shadow* w,
  deny /boot/** w,
}
EOF
            if [ -f /etc/apparmor.d/openwatch ]; then
                apparmor_parser -r -C /etc/apparmor.d/openwatch 2>/dev/null || true
                log_success "AppArmor profile configured (complain mode)"
            fi
        fi

        # Install systemd service files
        if [ -d /usr/share/openwatch/systemd ]; then
            log_info "Installing systemd service files..."
            cp /usr/share/openwatch/systemd/*.service /etc/systemd/system/ 2>/dev/null || true
            cp /usr/share/openwatch/systemd/*.target /etc/systemd/system/ 2>/dev/null || true
            systemctl daemon-reload
        fi

        # Enable services (but don't start)
        systemctl enable openwatch-api.service 2>/dev/null || true
        systemctl enable openwatch-worker@1.service 2>/dev/null || true
        systemctl enable openwatch-beat.service 2>/dev/null || true
        systemctl enable openwatch.target 2>/dev/null || true
        log_success "Services enabled"

        # Configure log rotation
        cat > /etc/logrotate.d/openwatch << 'EOF'
/var/log/openwatch/*.log {
    daily
    missingok
    rotate 14
    compress
    delaycompress
    notifempty
    create 0640 openwatch openwatch
    sharedscripts
    postrotate
        systemctl reload openwatch-api 2>/dev/null || true
    endscript
}
EOF

        # Ubuntu firewall hint
        if command -v ufw >/dev/null 2>&1; then
            if ufw status 2>/dev/null | grep -q "Status: active"; then
                log_warning "UFW is active. To allow OpenWatch access:"
                log_warning "  sudo ufw allow 80/tcp comment 'OpenWatch (nginx)'"
                log_warning "  sudo ufw allow 443/tcp comment 'OpenWatch TLS (nginx)'"
            fi
        fi

        # Final message
        echo ""
        log_success "OpenWatch installed successfully!"
        echo ""
        echo "Next steps:"
        echo "  1. Initialize PostgreSQL (if not already running):"
        echo "       sudo systemctl enable --now postgresql"
        echo "  2. Setup database:"
        echo "       sudo /usr/share/openwatch/scripts/setup-database.sh"
        echo "  3. Start Redis:"
        echo "       sudo systemctl enable --now redis-server"
        echo "  4. Configure TLS certificates in /etc/openwatch/ssl/"
        echo "  5. Configure nginx:"
        echo "       sudo ln -sf /etc/nginx/sites-available/openwatch /etc/nginx/sites-enabled/"
        echo "       sudo nginx -t && sudo systemctl reload nginx"
        echo "  6. Start OpenWatch:"
        echo "       sudo systemctl start openwatch.target"
        echo ""
        echo "Service management:"
        echo "  systemctl start openwatch.target     # Start all services"
        echo "  systemctl stop openwatch.target      # Stop all services"
        echo "  systemctl status openwatch-api       # Check API status"
        echo "  journalctl -u openwatch-api -f       # View API logs"
        echo ""
        echo "Admin commands:"
        echo "  owadm validate-config                # Validate configuration"
        echo "  owadm health                         # Health check"
        echo ""
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
