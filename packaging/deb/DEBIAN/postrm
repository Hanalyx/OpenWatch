#!/bin/bash
# OpenWatch Debian Post-Removal Script
# Final cleanup after package removal

set -e

SERVICE_USER="openwatch"
SERVICE_GROUP="openwatch"

case "$1" in
    purge)
        echo "Purging OpenWatch configuration and data..."

        # Remove systemd unit files that postinst copied
        rm -f /etc/systemd/system/openwatch-api.service
        rm -f /etc/systemd/system/openwatch-worker@.service
        rm -f /etc/systemd/system/openwatch-beat.service
        rm -f /etc/systemd/system/openwatch.target
        systemctl daemon-reload 2>/dev/null || true

        # Remove configuration
        if [ -d /etc/openwatch ]; then
            rm -rf /etc/openwatch
            echo "  Removed /etc/openwatch"
        fi

        # Remove logrotate config
        rm -f /etc/logrotate.d/openwatch

        # Remove nginx site config
        rm -f /etc/nginx/sites-enabled/openwatch
        rm -f /etc/nginx/sites-available/openwatch

        # Remove user and group
        if getent passwd $SERVICE_USER >/dev/null; then
            deluser --quiet $SERVICE_USER 2>/dev/null || true
            echo "  Removed user: $SERVICE_USER"
        fi
        if getent group $SERVICE_GROUP >/dev/null; then
            if [ -z "$(getent group $SERVICE_GROUP | cut -d: -f4)" ]; then
                delgroup --quiet $SERVICE_GROUP 2>/dev/null || true
                echo "  Removed group: $SERVICE_GROUP"
            fi
        fi

        # Warn about data directories (don't auto-remove DB data)
        if [ -d /var/lib/openwatch ] || [ -d /var/log/openwatch ]; then
            echo ""
            echo "Data directories preserved. To completely remove:"
            echo "  sudo rm -rf /var/lib/openwatch"
            echo "  sudo rm -rf /var/log/openwatch"
            echo "  sudo rm -rf /var/cache/openwatch"
            echo "  sudo -u postgres dropdb openwatch"
            echo "  sudo -u postgres dropuser openwatch"
            echo ""
        fi
        ;;

    remove)
        echo "OpenWatch removed (configuration and data preserved)"
        # Reload systemd to pick up removed unit files
        systemctl daemon-reload 2>/dev/null || true
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
